# Brewnet Go-Fiber Stack — Environment Variables
# Copy this file: cp .env.example .env

# ===== Common =====
PROJECT_NAME=brewnet
DOMAIN=localhost
DB_DRIVER=postgres          # postgres | mysql | sqlite3
BACKEND_PORT=8080
FRONTEND_PORT=3000
TZ=Asia/Seoul
STACK_LANG=go-fiber

# ===== PostgreSQL (DB_DRIVER=postgres) =====
DB_HOST=postgres
DB_PORT=5432
DB_NAME=brewnet_db
DB_USER=brewnet
DB_PASSWORD=password

# ===== MySQL (DB_DRIVER=mysql) =====
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=brewnet_db
MYSQL_USER=brewnet
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=password

# ===== SQLite3 (DB_DRIVER=sqlite3) =====
SQLITE_PATH=/app/data/brewnet_db.db
