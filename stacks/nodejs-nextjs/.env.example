# Brewnet Node.js-Next.js Stack — Environment Variables
# Copy this file: cp .env.example .env

# ===== Common =====
PROJECT_NAME=brewnet
DOMAIN=localhost
DB_DRIVER=postgres          # postgres | mysql | sqlite3
BACKEND_PORT=3000
FRONTEND_PORT=3000
TZ=Asia/Seoul
STACK_LANG=nodejs-nextjs

# ===== PostgreSQL (DB_DRIVER=postgres) =====
DB_HOST=postgres
DB_PORT=5432
DB_NAME=brewnet
DB_USER=brewnet
DB_PASSWORD=brewnet_secret

# ===== MySQL (DB_DRIVER=mysql) =====
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=brewnet
MYSQL_USER=brewnet
MYSQL_PASSWORD=brewnet_secret
MYSQL_ROOT_PASSWORD=root_secret

# ===== SQLite3 (DB_DRIVER=sqlite3) =====
SQLITE_PATH=/app/data/brewnet.db

# ===== Prisma (auto-configured based on DB_DRIVER) =====
PRISMA_DB_PROVIDER=postgresql
DATABASE_URL=postgresql://brewnet:brewnet_secret@postgres:5432/brewnet
